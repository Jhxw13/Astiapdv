{
  "name": "astia-pdv",
  "productName": "ASTIA PDV",
  "version": "1.0.0",
  "description": "ASTIA PDV — Sistema de gestão comercial em rede local. By VYN Developer.",
  "main": "src/main/index.js",
  "private": true,
  "scripts": {
    "dev:web": "vite",
    "dev": "cross-env NODE_ENV=development VYN_MODE=server concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:server": "cross-env NODE_ENV=development VYN_MODE=server concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:client": "cross-env NODE_ENV=development VYN_MODE=client electron .",
    "dev:debug": "cross-env NODE_ENV=development OPEN_DEVTOOLS=true VYN_MODE=server concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:web": "vite build",
    "build:servidor": "node scripts/download-vcredist.js && electron-builder --config electron-builder-server.yml",
    "build:cliente": "node scripts/download-vcredist.js && electron-builder --config electron-builder-client.yml",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3",
    "postinstall": "node scripts/rebuild-sqlite.js",
    "start": "cross-env VYN_MODE=server electron .",
    "license:keygen": "node scripts/license-keygen.js",
    "license:generate": "node scripts/license-generate.js",
    "download-vcredist": "node scripts/download-vcredist.js",
    "publicar": "node scripts/publicar-versao.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
